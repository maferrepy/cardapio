# ============================================================
# CONFIGURAÇÃO DO MERCADO PAGO
# ============================================================

# ACCESS TOKEN - Copie do painel do Mercado Pago:
# Sandbox (testes): https://www.mercadopago.com.br/developers/panel/app
# Produção:         mesmo painel, troque para credenciais de produção
#
# SANDBOX  → começa com TEST-
# PRODUÇÃO → começa com APP_USR-

MP_ACCESS_TOKEN=TEST-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ============================================================
# CONFIGURAÇÃO DO WEBHOOK
# ============================================================

# URL pública onde o Mercado Pago enviará notificações.
# Em desenvolvimento use ngrok: ngrok http 3001
# Ex: https://abc123.ngrok.io
WEBHOOK_BASE_URL=https://SEU_DOMINIO_OU_NGROK.io

# ============================================================
# CONFIGURAÇÃO DO SERVIDOR
# ============================================================
PORT=3001

# AMBIENTE: sandbox | production
NODE_ENV=sandbox
